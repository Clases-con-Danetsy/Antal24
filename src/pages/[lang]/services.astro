---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/Header.astro";
import Footer from "../../components/Footer.astro";
export const prerender = true;
export function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang || "es";
import { translations } from "../../locales.js";
const t = translations[lang as keyof typeof translations] ?? translations["es"];

const services =
    lang === "es"
        ? [
              {
                  num: "01",
                  id: "importaciones-y-exportaciones",
                  title: "Importaciones y Exportaciones",
                  desc: "Gestionamos el tránsito de mercancía nacional e internacional, asegurando que tus productos lleguen a su destino de forma segura y eficiente cumpliendo todas las normativas vigentes.",
                  items: [
                      "Importación y exportación de todo tipo de mercancía",
                      "Tránsito internacional de productos",
                      "Cumplimiento de normativas aduaneras",
                  ],
                  img: "https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=800",
              },
              {
                  num: "02",
                  id: "asesoria-legal-aduanal",
                  title: "Asesoría Legal Aduanal",
                  desc: "Contamos con especialistas en materia aduanal que te guiarán en cada paso del proceso de despacho, garantizando el cumplimiento legal en todo momento.",
                  items: [
                      "Asesoría personalizada en despacho aduanal",
                      "Gestión de documentación legal",
                      "Cumplimiento de regulaciones fiscales",
                  ],
                  img: "https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=800",
              },
              {
                  num: "03",
                  id: "cuaderno-ata",
                  title: "Cuaderno ATA",
                  desc: "Gestionamos carnés ATA para la importación temporal de mercancía, facilitando la participación en ferias, exposiciones y eventos internacionales sin pago de aranceles.",
