              },
              {
                  num: "04",
                  id: "tramites-ante-banjercito",
                  title: "Trámites ante BANJERCITO",
                  desc: "Realizamos todos los trámites necesarios ante BANJERCITO para la importación temporal de vehículos y mercancías, asegurando el cumplimiento de los requisitos legales.",
                  items: [
                      "Gestión de permisos de importación temporal",
                      "Trámites de vehículos extranjeros",
                      "Asesoría en requisitos BANJERCITO",
                  ],
                  img: "https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=800",
              },
              {
                  num: "05",
                  id: "certificaciones-noms-de-seguridad",
                  title: "Certificaciones de NOMs de Seguridad",
                  desc: "Gestionamos las certificaciones de Normas Oficiales Mexicanas de seguridad requeridas para la importación de productos, garantizando el cumplimiento normativo.",
                  items: [
                      "Certificación de productos de importación",
                      "Gestión ante organismos certificadores",
                      "Cumplimiento de NOMs de seguridad",
                  ],
                  img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800",
              },
              {
                  num: "06",
                  id: "cumplimiento-de-noms-de-etiquetado",
                  title: "Cumplimiento de NOMs de Etiquetado",
                  desc: "Asesoramos y gestionamos el cumplimiento de las Normas Oficiales Mexicanas de etiquetado, asegurando que tus productos cumplan con los requisitos de información al consumidor.",
                  items: [
                      "Revisión de etiquetado de productos",
                      "Adecuación a NOMs de etiquetado",
