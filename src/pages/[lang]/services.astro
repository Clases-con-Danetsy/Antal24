                      "Inscripción al Padrón Sectorial",
                      "Renovación de registros",
                      "Asesoría en requisitos sectoriales",
                  ],
                  img: "https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=800",
              },
              {
                  num: "08",
                  id: "almacen-deposito-fiscal",
                  title: "Almacén / Depósito Fiscal",
                  desc: "Gestionamos y administramos almacenes y depósitos fiscales, garantizando el resguardo seguro de tu mercancía bajo los lineamientos fiscales vigentes.",
                  items: [
                      "Almacenaje de mercancía nacional e internacional",
                      "Depósito fiscal bajo normativas del SAT",
                      "Control y seguimiento de inventarios",
                  ],
                  img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800",
              },
          ]
        : [
              {
                  num: "01",
                  id: "imports-exports",
                  title: "Imports & Exports",
                  desc: "We manage national and international merchandise transit, ensuring your products reach their destination safely and efficiently while complying with all current regulations.",
                  items: [
                      "Import and export of all types of merchandise",
                      "International product transit",
                      "Compliance with customs regulations",
                  ],
                  img: "https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=800",
              },
              {
                  num: "02",
                  id: "legal-customs-advisory",
                  title: "Legal Customs Advisory",
                  desc: "We have customs specialists who will guide you through each step of the clearance process, ensuring legal compliance at all times.",
                  items: [
                      "Personalized customs clearance advisory",
                      "Legal documentation management",
                      "Tax regulation compliance",
                  ],
                  img: "https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=800",
              },
              {
                  num: "03",
                  id: "ata-carnet",
                  title: "ATA Carnet",
                  desc: "We manage ATA carnets for the temporary import of merchandise, facilitating participation in fairs, exhibitions and international events without paying customs duties.",
                  items: [
                      "Complete ATA carnet management",
                      "Temporary import without customs duties",
                      "Ideal for international events and exhibitions",
                  ],
                  img: "https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=800",
              },
              {
                  num: "04",
                  id: "banjercito-procedures",
                  title: "BANJERCITO Procedures",
                  desc: "We carry out all necessary procedures before BANJERCITO for the temporary import of vehicles and merchandise, ensuring compliance with legal requirements.",
                  items: [
                      "Temporary import permit management",
                      "Foreign vehicle procedures",
                      "BANJERCITO requirements advisory",
                  ],
                  img: "https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=800",
              },
              {
                  num: "05",
                  id: "safety-nom-certifications",
                  title: "Safety NOM Certifications",
                  desc: "We manage the certifications of Mexican Official Standards required for the import of products, guaranteeing regulatory compliance.",
                  items: [
                      "Import product certification",
                      "Management before certifying bodies",
                      "Safety NOM compliance",
                  ],
                  img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800",
              },
              {
                  num: "06",
                  id: "labeling-nom-compliance",
                  title: "Labeling NOM Compliance",
                  desc: "We advise and manage compliance with Mexican Official Labeling Standards, ensuring your products meet consumer information requirements.",
                  items: [
                      "Product labeling review",
                      "Adaptation to labeling NOMs",
                      "Consumer information advisory",
                  ],
                  img: "https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=800",
              },
              {
                  num: "07",
                  id: "sectoral-registry",
                  title: "Textile, Footwear and Steel Sectoral Registry",
                  desc: "We manage registration and renewal in the Sectoral Registry for the Textile, Footwear and Steel sectors, an essential requirement for importing products in these sectors.",
                  items: [
                      "Sectoral Registry registration",
                      "Record renewal",
                      "Sector requirements advisory",
                  ],
                  img: "https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=800",
              },
              {
                  num: "08",
                  id: "warehouse-fiscal-deposit",
                  title: "Warehouse / Fiscal Deposit",
                  desc: "We manage and administer warehouses and fiscal deposits, guaranteeing the secure storage of your merchandise under current fiscal regulations.",
                  items: [
                      "Storage of national and international merchandise",
                      "Fiscal deposit under SAT regulations",
                      "Inventory control and tracking",
                  ],
                  img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800",
              },
          ];

const logisticsIds =
    lang === "es"
        ? [
              "fletes-terrestres",
              "logistica-internacional",
              "gestoria-maritima",
              "gestoria-aerea",
          ]
        : [
              "land-freight",
              "international-logistics",
              "maritime-agency",
              "air-agency",
          ];

const logistics =
    lang === "es"
        ? [
              {
                  num: "01",
                  title: "Flete Terrestre",
                  desc: "Cobertura nacional con tiempos de entrega óptimos y rastreo en tiempo real.",
                  items: [
                      "Cobertura nacional",
                      "Rastreo en tiempo real",
                      "Seguro de carga incluido",
                  ],
                  img: "https://images.unsplash.com/photo-1577705998148-6da4f3963bc8?w=800",
              },
              {
                  num: "02",
                  title: "Logística Internacional",
                  desc: "Soluciones multimodales para conectar tu negocio con mercados globales.",
                  items: [
                      "Conexión con mercados globales",
                      "Coordinación multimodal",
                      "Seguimiento de embarques",
                  ],
                  img: "https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=800",
              },
              {
                  num: "03",
                  title: "Flete Marítimo",
                  desc: "Coordinación integral de envíos marítimos desde el origen hasta la entrega.",
                  items: [
                      "Coordinación de envíos marítimos",
                      "Gestión de documentación",
                      "Seguimiento de embarques",
                  ],
                  img: "https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=800",
              },
              {
                  num: "04",
                  title: "Flete Aéreo",
                  desc: "Envíos express para mercancía urgente o de alto valor al mejor precio.",
                  items: [
                      "Envíos aéreos express",
                      "Gestión de carga aérea",
                      "Coordinación con aerolíneas",
                  ],
                  img: "https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=800",
              },
          ]
        : [
              {
                  num: "01",
                  title: "Land Freight",
                  desc: "National coverage with optimal delivery times and real-time tracking.",
                  items: [
                      "National coverage",
                      "Real-time tracking",
                      "Cargo insurance included",
                  ],
                  img: "https://images.unsplash.com/photo-1577705998148-6da4f3963bc8?w=800",
              },
              {
                  num: "02",
                  title: "International Logistics",
                  desc: "Multimodal solutions to connect your business with global markets.",
                  items: [
                      "Connection with global markets",
                      "Multimodal coordination",
                      "Shipment tracking",
                  ],
                  img: "https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=800",
              },
              {
                  num: "03",
                  title: "Maritime Freight",
                  desc: "End-to-end coordination of maritime shipments from origin to delivery.",
                  items: [
                      "Maritime shipment coordination",
                      "Documentation management",
                      "Shipment tracking",
                  ],
                  img: "https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=800",
              },
              {
                  num: "04",
                  title: "Air Freight",
                  desc: "Express shipments for urgent or high-value merchandise at the best price.",
                  items: [
                      "Express air shipments",
                      "Air cargo management",
                      "Airline coordination",
                  ],
                  img: "https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=800",
              },
          ];
---

<Layout lang={lang}>
    <Header lang={lang} />

    <!-- HERO -->
    <section
        class="relative min-h-[400px] md:min-h-[500px] flex items-center justify-center bg-secondary-color overflow-hidden"
    >
        <div class="absolute inset-0">
            <img
                src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=1600"
                alt="servicios"
                class="w-full h-full object-cover opacity-30"
            />
        </div>
        <div class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">
            <h1
                data-aos="fade-down"
                data-aos-duration="1000"
                class="text-3xl md:text-6xl font-bold text-white mb-6 leading-tight"
                style="font-family: 'Trebuchet MS', sans-serif;"
            >
                {lang === "es" ? "Nuestros " : "Our "}<span
                    style="color: #39a08b;"
                    >{lang === "es" ? "Servicios" : "Services"}</span
                >
            </h1>
            <p
                data-aos="fade-up"
                data-aos-delay="300"
                class="text-xl text-white opacity-90"
            >
                {
                    lang === "es"
                        ? "Soluciones integrales para tu comercio exterior y logística"
                        : "Comprehensive solutions for your foreign trade and logistics"
                }
            </p>
        </div>
    </section>

    <!-- SERVICIOS QUE OFRECEMOS -->
    <section class="py-24 bg-gray-100">
        <div class="max-w-6xl mx-auto px-6">
            <h2
                data-aos="fade-up"
                class="text-4xl font-bold text-secondary-color text-center mb-4"
            >
                {
                    lang === "es"
                        ? "Servicios que ofrecemos"
                        : "Services we offer"
                }
            </h2>
            <div
                data-aos="fade-up"
                data-aos-delay="100"
                class="w-24 h-1 bg-primary-color mx-auto mb-20"
            >
            </div>
            <div class="flex flex-col gap-32">
                {
                    services.map((service, i) => (
                        <div
                            id={service.id}
                            class={`animate-service-${i} flex flex-col md:flex-row gap-12 items-center ${i % 2 !== 0 ? "md:flex-row-reverse" : ""}`}
                            style="scroll-margin-top: 120px;"
                        >
                            <div class="w-full md:w-1/2 rounded-xl overflow-hidden shadow-lg flex-shrink-0 group">
                                <img
                                    src={service.img}
                                    alt={service.title}
                                    class="w-full h-96 object-cover scale-110 group-hover:scale-100 transition-transform duration-500"
                                />
                            </div>
                            <div class="w-full md:w-1/2">
                                <span class="text-primary-color text-sm font-bold uppercase tracking-widest">
                                    {lang === "es" ? "Servicio" : "Service"}{" "}
                                    {service.num}
                                </span>
                                <h3
                                    class="text-secondary-color font-bold text-3xl mt-2 mb-4"
                                    style="font-family: 'Trebuchet MS', sans-serif;"
                                >
                                    {service.title}
                                </h3>
                                <div class="w-10 h-0.5 bg-primary-color mb-5" />
                                <p class="text-gray-500 text-base leading-relaxed mb-6">
                                    {service.desc}
                                </p>
                                <ul class="flex flex-col gap-3">
                                    {service.items.map((item) => (
                                        <li class="flex items-center gap-3 text-base text-gray-600">
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary-color flex-shrink-0" />
                                            {item}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- SERVICIOS LOGÍSTICOS -->
    <section class="py-24" style="background-color: #f8f9fa;">
        <div class="max-w-6xl mx-auto px-6">
            <h2
                data-aos="fade-up"
                class="text-4xl font-bold text-secondary-color text-center mb-4"
            >
                {lang === "es" ? "Servicios Logísticos" : "Logistics Services"}
            </h2>
            <div
                data-aos="fade-up"
                data-aos-delay="100"
                class="w-24 h-1 bg-primary-color mx-auto mb-20"
            >
            </div>
            <div class="flex flex-col gap-32">
                {
                    logistics.map((service, i) => (
                        <div
                            id={logisticsIds[i]}
                            class={`animate-logistics-${i} flex flex-col md:flex-row gap-12 items-center ${i % 2 !== 0 ? "md:flex-row-reverse" : ""}`}
                            style="scroll-margin-top: 120px;"
                        >
                            <div class="w-full md:w-1/2 rounded-xl overflow-hidden shadow-lg flex-shrink-0 group">
                                <img
                                    src={service.img}
                                    alt={service.title}
                                    class="w-full h-96 object-cover scale-110 group-hover:scale-100 transition-transform duration-500"
                                />
                            </div>
                            <div class="w-full md:w-1/2">
                                <span class="text-primary-color text-sm font-bold uppercase tracking-widest">
                                    {lang === "es" ? "Logística" : "Logistics"}{" "}
                                    {service.num}
                                </span>
                                <h3
                                    class="text-secondary-color font-bold text-3xl mt-2 mb-4"
                                    style="font-family: 'Trebuchet MS', sans-serif;"
                                >
                                    {service.title}
                                </h3>
                                <div class="w-10 h-0.5 bg-primary-color mb-5" />
                                <p class="text-gray-500 text-base leading-relaxed mb-6">
                                    {service.desc}
                                </p>
                                <ul class="flex flex-col gap-3">
                                    {service.items.map((item) => (
                                        <li class="flex items-center gap-3 text-base text-gray-600">
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary-color flex-shrink-0" />
                                            {item}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <Footer lang={lang} />

    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("in-view");
                } else {
                    entry.target.classList.remove("in-view");
                }
            });
        });

        document
            .querySelectorAll(
                ".animate-service-0, .animate-service-1, .animate-service-2, .animate-service-3, .animate-service-4, .animate-service-5, .animate-service-6, .animate-service-7, .animate-logistics-0, .animate-logistics-1, .animate-logistics-2, .animate-logistics-3",
            )
            .forEach((el) => observer.observe(el));
    </script>
</Layout>
