---
// src/pages/[lang]/noticias.astro

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/Header.astro";
import Footer from "../../components/Footer.astro";

export const prerender = true;

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang || "es";
import { translations } from "../../locales.js";
const t = translations[lang as keyof typeof translations] ?? translations["es"];
---

<Layout lang={lang}>
  <Header lang={lang} />

  <!-- HERO -->
  <section
    class="relative min-h-[400px] md:min-h-[500px] flex items-center justify-center bg-secondary-color overflow-hidden"
  >
    <div class="absolute inset-0">
      <img
        src="/imagenes/hero_noticias.png"
        alt="noticias"
        class="w-full h-full object-cover opacity-20"
      />
    </div>
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">
      <h1
        data-aos="fade-down"
        data-aos-duration="1000"
        class="text-3xl md:text-6xl font-bold text-white mb-6 leading-tight"
        style="font-family: 'Trebuchet MS', sans-serif;"
      >
        {lang === "es" ? "No" : "Ne"}<span style="color: #39a08b;"
          >{lang === "es" ? "ticias" : "ws"}</span
        >
      </h1>
      <p
        data-aos="fade-up"
        data-aos-delay="300"
        class="text-lg md:text-xl text-white opacity-90"
      >
        {
          lang === "es"
            ? "Mantente informado sobre las últimas novedades en comercio exterior, logística y despacho aduanal."
            : "Stay informed about the latest news in foreign trade, logistics and customs clearance."
        }
      </p>
    </div>
  </section>

  <div class="w-full h-1 bg-primary-color"></div>

  <!-- NOTICIAS -->
  <main class="max-w-4xl mx-auto px-6 py-16 flex flex-col gap-10">
    <div id="news-container">
      <div style="text-align:center; padding: 4rem 0; color: #6b7280;">
        <p style="font-size:18px; font-weight:600;">
          {lang === "es" ? "Cargando noticias..." : "Loading news..."}
        </p>
      </div>
    </div>
  </main>

  <Footer lang={lang} />

  <script define:vars={{ lang }}>
    const container = document.getElementById("news-container");

    async function loadNews() {
      try {
        const base =
          window.location.hostname === "localhost"
            ? "http://localhost/antal24"
            : "";

        const res = await fetch(`${base}/admin/noticias.php`);
        const data = await res.json();

        if (!data.ok || !Array.isArray(data.noticias)) {
          throw new Error("Invalid API response");
        }

        if (data.noticias.length === 0) {
          container.innerHTML = `
            <div style="text-align:center; padding: 4rem 0; color: #6b7280;">
              <p style="font-size:18px; font-weight:600;">
                ${lang === "es" ? "No hay noticias publicadas aún." : "No news published yet."}
              </p>
            </div>`;
          return;
        }

        const gradients = [
          "linear-gradient(135deg, #062d76 50%, #39a08b)",
          "linear-gradient(135deg, #062d76 40%, #0a3d8f)",
          "linear-gradient(135deg, #062d76 50%, #2d7a5e)",
        ];

        const html = data.noticias
          .map((n, i) => {
            const categoria = lang === "es" ? n.categoria_es : n.categoria_en;
            const fecha = lang === "es" ? n.fecha_es : n.fecha_en;
            const titulo = lang === "es" ? n.titulo_es : n.titulo_en;
            const contenido = lang === "es" ? n.contenido_es : n.contenido_en;
            const tags = lang === "es" ? n.tags_es : n.tags_en;

            const separator =
              i < data.noticias.length - 1
                ? `
            <div style="display:flex; align-items:center; gap:12px; margin-top:2.5rem;">
              <div style="flex:1; height:1px; background:rgba(173,172,177,0.3);"></div>
              <div style="width:8px; height:8px; border-radius:50%; background:#39a08b;"></div>
              <div style="flex:1; height:1px; background:rgba(173,172,177,0.3);"></div>
            </div>`
                : "";

            return `
            <div>
              <article style="
                background: white;
                border-radius: 16px;
                overflow: hidden;
                border: 0.5px solid rgba(173,172,177,0.3);
                box-shadow: 0 4px 32px rgba(6,45,118,0.06);
              ">

                <!-- Imagen / gradiente con badges -->
                <div style="
                  position: relative;
                  height: 40%;
                  overflow: hidden;
                  ${n.imagen ? "" : `background: ${gradients[i % gradients.length]};`}
                  display: flex;
                  align-items: center;
                  justify-content: center;
                ">
                  ${
                    n.imagen
                      ? `<img src="${n.imagen}" alt="${titulo}" style="width:100%; height:100%; object-fit:cover; display:block;" />`
                      : `<svg style="width:64px; height:64px; opacity:0.12; position:relative; z-index:1;" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                       </svg>`
                  }

                  <!-- Badge categoría (arriba izquierda) -->
                  <span style="
                    position: absolute;
                    top: 16px;
                    left: 16px;
                    background: #39a08b;
                    color: white;
                    font-size: 10px;
                    font-weight: 600;
                    letter-spacing: 1.5px;
                    text-transform: uppercase;
                    padding: 4px 12px;
                    border-radius: 4px;
                    z-index: 2;
                  ">${categoria}</span>

                  <!-- Badge fecha (abajo derecha) -->
                  <span style="
                    position: absolute;
                    bottom: 16px;
                    right: 16px;
                    background: rgba(6,45,118,0.85);
                    color: white;
                    font-size: 11px;
                    padding: 4px 12px;
                    border-radius: 4px;
                    z-index: 2;
                  ">${fecha}</span>
                </div>

                <!-- Cuerpo -->
                <div style="padding: 2rem 2.5rem;">

                  <!-- Metadata row -->
                  <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:12px;">
                    <span style="font-size:10px; font-weight:600; color:#39a08b; text-transform:uppercase; letter-spacing:1.5px;">${categoria}</span>
                    <span style="width:4px; height:4px; border-radius:50%; background:#adacb1; display:inline-block;"></span>
                    <span style="font-size:11px; color:#adacb1;">${fecha}</span>
                    <span style="width:4px; height:4px; border-radius:50%; background:#adacb1; display:inline-block;"></span>
                    <span style="font-size:11px; color:#adacb1;">Equipo ANTAL24</span>
                  </div>

                  <!-- Título -->
                  <h2 style="
                    font-family: 'Trebuchet MS', sans-serif;
                    font-size: 22px;
                    font-weight: 700;
                    color: #062d76;
                    line-height: 1.35;
                    margin-bottom: 12px;
                  ">${titulo}</h2>

                  <!-- Línea decorativa verde -->
                  <div style="width:36px; height:3px; background:#39a08b; border-radius:2px; margin-bottom:20px;"></div>

                  <!-- Párrafos -->
                  <div style="display:flex; flex-direction:column; gap:12px;">
                    ${contenido
                      .map(
                        (p) => `
                      <p style="font-size:14px; color:#6b7280; line-height:1.85;">${p}</p>
                    `,
                      )
                      .join("")}
                  </div>

                  <!-- Tags -->
                  <div style="
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                    margin-top: 24px;
                    padding-top: 20px;
                    border-top: 0.5px solid rgba(173,172,177,0.25);
                  ">
                    ${tags
                      .map(
                        (tag) => `
                      <span style="
                        font-size: 10px;
                        font-weight: 500;
                        color: #062d76;
                        padding: 4px 12px;
                        border-radius: 20px;
                        background: rgba(6,45,118,0.07);
                        border: 0.5px solid rgba(6,45,118,0.15);
                      ">${tag}</span>
                    `,
                      )
                      .join("")}
                  </div>

                </div>
              </article>
              ${separator}
            </div>`;
          })
          .join("");

        container.innerHTML = html;

        // Intersection observer para animaciones
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
            } else {
              entry.target.classList.remove("in-view");
            }
          });
        });
        container
          .querySelectorAll("article")
          .forEach((el) => observer.observe(el));
      } catch (err) {
        console.error(err);
        container.innerHTML = `
          <div style="text-align:center; padding: 4rem 0; color:red;">
            ${lang === "es" ? "Error al cargar noticias." : "Error loading news."}
          </div>`;
      }
    }

    loadNews();
  </script>
</Layout>
