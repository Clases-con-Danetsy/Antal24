---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/Header.astro";
import Footer from "../../components/Footer.astro";
import MapaSocios from "../../components/Headers/MapaSocios.astro";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang || "es";
import { translations } from "../../locales.js";
const t = translations[lang as keyof typeof translations] ?? translations["es"];
---

<Layout lang={lang}>
  <Header lang={lang} />

  <!-- HERO — azul -->
  <section
    class="relative min-h-[525px] md:min-h-[80vh] flex items-center justify-center bg-secondary-color overflow-hidden"
  >
    <div class="absolute inset-0 overflow-hidden">
      <video
        autoplay
        muted
        loop
        playsinline
        class="absolute hero-video"
        style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: max(100%, 177.78vh); height: max(100%, 56.25vw); pointer-events: none; object-fit: cover;"
      >
        <source src="/videos/final.mp4" type="video/mp4" />
      </video>
      <div
        class="absolute inset-0 hidden md:block"
        style="background: linear-gradient(to top, rgba(6,45,118,0.8) 0%, transparent 50%);"
      >
      </div>
      <div
        class="absolute inset-0 hidden md:block"
        style="background: linear-gradient(to bottom, rgba(6,45,118,0.5) 0%, transparent 50%);"
      >
      </div>
    </div>

    <div class="relative z-10 text-center px-6 md:pt-72 max-w-4xl mx-auto">
      <h1
        data-aos="fade-down"
        data-aos-duration="1000"
        class="text-3xl md:text-7xl font-bold text-white mb-6 leading-tight"
        style="font-family: 'Trebuchet MS', sans-serif;"
      >
        Get it easy, <span style="color: #7dc5b5;">get it safe!</span>
      </h1>
      <p
        data-aos="fade-up"
        data-aos-delay="300"
        class="text-xl md:text-2xl text-white mb-10 opacity-90"
      >
        {t.hero.subtitle}
      </p>
    </div>
  </section>

  <div class="w-full h-1" style="background-color: #7dc5b5;"></div>

  <!-- 3 PILARES — blanco -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div
        class="animate-on-load relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=600"
          alt="Comercializadora"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to top, rgba(6,45,118,0.9) 0%, rgba(6,45,118,0.3) 60%, transparent 100%);"
        >
        </div>
        <div></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.comercializadora}</h3>
          <div
            class="w-10 h-0.5 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background-color: #7dc5b5;"
          >
          </div>
        </div>
      </div>

      <div
        class="animate-on-load-delay-1 relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="/imagenes/logistica.png"
          alt="Logística"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to top, rgba(6,45,118,0.9) 0%, rgba(6,45,118,0.3) 60%, transparent 100%);"
        >
        </div>
        <div></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.logistica}</h3>
          <div
            class="w-10 h-0.5 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background-color: #7dc5b5;"
          >
          </div>
        </div>
      </div>

      <div
        class="animate-on-load-delay-2 relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="/imagenes/despachoaduanal.png"
          alt="Despacho Aduanal"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to top, rgba(6,45,118,0.9) 0%, rgba(6,45,118,0.3) 60%, transparent 100%);"
        >
        </div>
        <div></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.aduanal}</h3>
          <div
            class="w-10 h-0.5 mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background-color: #7dc5b5;"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS — verde suave -->
  <section class="py-20" style="background-color: #7dc5b5;">
    <div class="max-w-7xl mx-auto px-6">
      <h2
        data-aos="fade-up"
        class="text-4xl font-bold text-secondary-color text-center mb-4"
      >
        {t.services.title}
      </h2>
      <div
        data-aos="fade-up"
        data-aos-delay="100"
        class="w-24 h-1 bg-secondary-color mx-auto mb-14"
      >
      </div>
    </div>
    <div class="max-w-5xl mx-auto px-6 relative">
      <!-- Flecha prev fuera — doble -->
      <button
        id="srv-prev"
        class="hidden md:block absolute left-[-52px] top-1/2 -translate-y-1/2 z-10 opacity-90 hover:opacity-100 transition-opacity bg-transparent border-none cursor-pointer"
        aria-label="Anterior"
      >
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
          <path
            d="M28 8l-12 14 12 14"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M34 8l-12 14 12 14"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      <div class="swiper swiper-servicios">
        <div class="swiper-wrapper">
          {
            t.services.items.map(
              (service: { title: string; desc: string }, i: number) => (
                <div class="swiper-slide">
                  <div class="relative rounded-xl overflow-hidden shadow-lg group h-72">
                    <img
                      src={`https://images.unsplash.com/photo-${["1577705998148-6da4f3963bc8", "1494412574643-ff11b0a5c1c3", "1504711434969-e33886168f5c", "1521737852567-6949f3f9f2b5", "1578575437130-527eed3abbec", "1504711434969-e33886168f5c", "1494412574643-ff11b0a5c1c3"][i % 7]}?w=600`}
                      alt={service.title}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-125"
                    />
                    <div
                      class="absolute inset-0 transition-opacity duration-500"
                      style="background: linear-gradient(to top, rgba(6,45,118,0.9) 0%, rgba(6,45,118,0.3) 60%, transparent 100%);"
                    />
                    <div class="absolute inset-0 flex flex-col justify-end p-6">
                      <h3
                        class="text-white font-bold text-2xl mb-2"
                        style="font-family: 'Barlow Condensed', sans-serif; letter-spacing: 1px;"
                      >
                        {service.title}
                      </h3>
                      <p class="text-white text-sm opacity-90">
                        {service.desc}
                      </p>
                    </div>
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>

      <!-- Flecha next fuera — doble -->
      <button
        id="srv-next"
        class="hidden md:block absolute right-[-52px] top-1/2 -translate-y-1/2 z-10 opacity-90 hover:opacity-100 transition-opacity bg-transparent border-none cursor-pointer"
        aria-label="Siguiente"
      >
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
          <path
            d="M16 8l12 14-12 14"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path
            d="M10 8l12 14-12 14"
            stroke="white"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      <!-- Bolitas blancas fuera -->
      <div class="swiper-pagination-servicios flex justify-center gap-2 mt-5">
      </div>
    </div>
  </section>

  <div class="text-center py-10" style="background-color: #7dc5b5;">
    <a
      href={`/${lang}/services`}
      data-aos="fade-up"
      class="text-secondary-color font-semibold border-2 border-secondary-color px-7 py-2 rounded-full hover:bg-secondary-color hover:text-white transition-colors"
    >
      {lang === "es" ? "Ver todos los servicios" : "View all services"}
    </a>
  </div>

  <!-- SERVICIOS LOGÍSTICOS — azul -->
  <section class="py-20 bg-secondary-color">
    <div class="max-w-3xl mx-auto px-6">
      <h2
        data-aos="fade-up"
        class="text-4xl font-bold text-white text-center mb-4"
      >
        {t.services.logisticsTitle}
      </h2>
      <div
        data-aos="fade-up"
        data-aos-delay="100"
        class="w-24 h-1 mx-auto mb-14"
        style="background-color: #7dc5b5;"
      >
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          t.services.logistics.map(
            (service: { title: string; desc: string }, i: number) => (
              <div
                data-aos="fade-up"
                data-aos-delay={i * 150}
                class="relative rounded-xl overflow-hidden shadow-lg group h-64"
              >
                <img
                  src={`https://images.unsplash.com/photo-${["1577705998148-6da4f3963bc8", "1494412574643-ff11b0a5c1c3", "1578575437130-527eed3abbec", "1504711434969-e33886168f5c"][i % 4]}?w=600`}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-125"
                />
                <div
                  class="absolute inset-0 transition-opacity duration-500"
                  style="background: linear-gradient(to top, rgba(6,45,118,0.9) 0%, rgba(6,45,118,0.3) 60%, transparent 100%);"
                />
                <div class="absolute inset-0 flex flex-col justify-end p-6">
                  <h3 class="text-white font-bold text-xl mb-2">
                    {service.title}
                  </h3>
                  <p class="text-white text-sm opacity-90">{service.desc}</p>
                </div>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- MAPA SOCIOS — reemplaza cobertura -->
  <MapaSocios lang={lang} />

  <!-- NOTICIAS — blanco -->
  <section class="py-20 bg-white">
    <h2
      data-aos="fade-up"
      class="text-4xl font-bold text-secondary-color text-center mb-4"
    >
      {t.news.title}
    </h2>
    <div
      data-aos="fade-up"
      data-aos-delay="100"
      class="w-24 h-1 mx-auto mb-14"
      style="background-color: #7dc5b5;"
    >
    </div>
    <!-- TIPO DE CAMBIO WIDGET -->
    <div
      data-aos="fade-up"
      data-aos-delay="150"
      class="max-w-xl mx-auto mb-12 p-6 bg-gray-50 border border-gray-100 rounded-2xl shadow-sm"
    >
      <h3
        class="text-lg font-bold text-secondary-color text-center mb-4 flex items-center justify-center gap-2"
      >
        <svg
          class="w-5 h-5 text-primary-color"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        {t.indicators.title}
      </h3>

      <form
        id="indicators-form"
        class="flex flex-col sm:flex-row items-end justify-center gap-4"
        data-lang={lang}
        data-loading-text={t.indicators.loading}
        data-error-text={t.indicators.error}
        data-no-data-text={t.indicators.noData}
        data-validation-text={t.indicators.validationError}
      >
        <div class="flex flex-col gap-1 w-full sm:w-auto">
          <label
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
            >{t.indicators.startDate}</label
          >
          <input
            type="date"
            id="ind-start-date"
            required
            class="w-full sm:w-44 px-3 py-2 text-sm border border-gray-200 rounded-lg text-secondary-color bg-white focus:outline-none focus:border-primary-color focus:ring-2 focus:ring-primary-color/10 transition-all"
          />
        </div>
        <div class="flex flex-col gap-1 w-full sm:w-auto">
          <label
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
            >{t.indicators.endDate}</label
          >
          <input
            type="date"
            id="ind-end-date"
            required
            class="w-full sm:w-44 px-3 py-2 text-sm border border-gray-200 rounded-lg text-secondary-color bg-white focus:outline-none focus:border-primary-color focus:ring-2 focus:ring-primary-color/10 transition-all"
          />
        </div>
        <button
          type="submit"
          class="w-full sm:w-auto px-6 py-2 text-sm font-semibold text-white bg-secondary-color hover:bg-secondary-color/90 border border-transparent rounded-lg shadow-sm transition-all hover:shadow cursor-pointer flex items-center justify-center gap-2 group"
        >
          {t.indicators.button}
          <svg
            class="w-4 h-4 text-white/80 group-hover:translate-x-0.5 transition-transform"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </button>
      </form>
    </div>

    <!-- MODAL INDICADORES -->
    <div
      id="indicators-modal"
      style="display:none;"
      class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-secondary-color/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"
    >
      <div
        class="relative w-full max-w-md bg-white border border-gray-100 rounded-2xl shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300"
        id="indicators-modal-card"
      >
        <!-- Header -->
        <div
          class="px-6 py-4 border-b border-gray-100 flex items-center justify-between bg-gray-50"
        >
          <h4
            class="text-lg font-bold text-secondary-color flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-primary-color"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              ></path>
            </svg>
            {t.indicators.modalTitle}
          </h4>
          <button
            id="indicators-modal-close-btn"
            class="text-gray-400 hover:text-gray-600 transition-colors bg-none border-none p-1 cursor-pointer"
            aria-label="Cerrar"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Body -->
        <div class="p-6">
          <p class="text-xs text-gray-500 mb-4 leading-relaxed">
            {t.indicators.modalDesc}
          </p>

          <!-- Loading spinner -->
          <div
            id="ind-modal-loading"
            class="hidden py-8 flex flex-col items-center justify-center gap-3"
          >
            <div
              class="w-8 h-8 border-4 border-primary-color border-t-transparent rounded-full animate-spin"
            >
            </div>
            <span class="text-sm font-medium text-secondary-color"
              >{t.indicators.loading}</span
            >
          </div>

          <!-- Error message -->
          <div
            id="ind-modal-error"
            class="hidden p-4 text-sm text-red-700 bg-red-50 border border-red-100 rounded-lg text-center font-medium"
          >
            {t.indicators.error}
          </div>

          <!-- Data table wrapper -->
          <div id="ind-modal-data-wrapper" class="hidden">
            <div
              class="max-h-[300px] overflow-y-auto border border-gray-100 rounded-xl"
            >
              <table class="w-full text-sm text-left text-gray-500">
                <thead
                  class="text-xs text-secondary-color uppercase bg-gray-50 border-b border-gray-100 sticky top-0"
                >
                  <tr>
                    <th scope="col" class="px-6 py-3 font-semibold"
                      >{t.indicators.dateCol}</th
                    >
                    <th scope="col" class="px-6 py-3 font-semibold"
                      >{t.indicators.valueCol}</th
                    >
                  </tr>
                </thead>
                <tbody id="ind-table-body">
                  <!-- Dynamic rows -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div
          class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end"
        >
          <button
            id="indicators-modal-close-footer"
            class="px-5 py-2 text-sm font-semibold text-gray-700 hover:text-gray-900 bg-white hover:bg-gray-100 border border-gray-200 rounded-lg shadow-sm transition-colors cursor-pointer"
          >
            {lang === "es" ? "Cerrar" : "Close"}
          </button>
        </div>
      </div>
    </div>
    <div class="max-w-5xl mx-auto px-6">
      <div class="relative">
        <!-- Flecha prev fuera — doble azul -->
        <button
          id="news-prev"
          class="hidden md:block absolute left-[-52px] top-[45%] -translate-y-1/2 z-10 opacity-80 hover:opacity-100 transition-opacity bg-transparent border-none cursor-pointer"
          aria-label="Anterior"
        >
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
            <path
              d="M28 8l-12 14 12 14"
              stroke="#062d76"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M34 8l-12 14 12 14"
              stroke="#062d76"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <div class="swiper swiper-noticias">
          <div id="home-news-wrapper" class="swiper-wrapper py-4"></div>
        </div>

        <!-- Flecha next fuera — doble azul -->
        <button
          id="news-next"
          class="hidden md:block absolute right-[-52px] top-[45%] -translate-y-1/2 z-10 opacity-80 hover:opacity-100 transition-opacity bg-transparent border-none cursor-pointer"
          aria-label="Siguiente"
        >
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
            <path
              d="M16 8l12 14-12 14"
              stroke="#062d76"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M10 8l12 14-12 14"
              stroke="#062d76"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <!-- Bullets externos -->
        <div class="swiper-pagination-noticias flex justify-center gap-2 mt-5">
        </div>
      </div>

      <div data-aos="fade-up" class="text-center mt-16">
        <a
          href={`/${lang}/news`}
          class="text-secondary-color font-semibold border-2 border-secondary-color px-7 py-2 rounded-full hover:bg-secondary-color hover:text-white transition-colors"
        >
          {t.news.viewAll}
        </a>
      </div>
    </div>
  </section>

  <Footer lang={lang} />

  <style is:global>
    /* Elimina franjas negras del video solo en mobile */
    @media (max-width: 767px) {
      .hero-video {
        transform: translate(-50%, -65%) scale(1.55) !important;
      }
    }

    .swiper-pagination-servicios .swiper-pagination-bullet {
      width: 10px;
      height: 10px;
      background: white !important;
      opacity: 0.5;
      border-radius: 50%;
      cursor: pointer;
      display: inline-block;
      transition: opacity 0.2s;
    }
    .swiper-pagination-servicios .swiper-pagination-bullet-active {
      opacity: 1 !important;
    }
    .swiper-pagination-noticias .swiper-pagination-bullet {
      width: 10px;
      height: 10px;
      background: #062d76 !important;
      opacity: 0.4;
      border-radius: 50%;
      cursor: pointer;
      display: inline-block;
      transition: opacity 0.2s;
    }
    .swiper-pagination-noticias .swiper-pagination-bullet-active {
      opacity: 1 !important;
    }
  </style>

  <script>
    import Swiper from "swiper";
    import { Navigation, Pagination, Autoplay } from "swiper/modules";
    import "swiper/css";
    import "swiper/css/navigation";
    import "swiper/css/pagination";

    // ── Servicios (datos estáticos, se inicializa de inmediato) ──
    new Swiper(".swiper-servicios", {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: { delay: 3000, disableOnInteraction: false },
      navigation: {
        nextEl: "#srv-next",
        prevEl: "#srv-prev",
      },
      pagination: {
        el: ".swiper-pagination-servicios",
        clickable: true,
      },
      breakpoints: {
        640: { slidesPerView: 2, spaceBetween: 20 },
        1024: { slidesPerView: 3, spaceBetween: 24 },
      },
    });

    // ── Noticias: se inicializa DESPUÉS de cargar los slides desde la API ──
    window.__initHomeNews = function (
      Swiper,
      Navigation,
      Pagination,
      Autoplay,
    ) {
      const wrapper = document.getElementById("home-news-wrapper");
      if (!wrapper) return;
      const currentLang = document.documentElement.lang || "es";
      const base =
        window.location.hostname === "localhost"
          ? "http://localhost/antal24"
          : "";

      const gradients = [
        "linear-gradient(135deg, #062d76 50%, #39a08b)",
        "linear-gradient(135deg, #062d76 40%, #0a3d8f)",
        "linear-gradient(135deg, #062d76 50%, #2d7a5e)",
      ];

      fetch(`${base}/admin/noticias.php`)
        .then((r) => r.json())
        .then((data) => {
          if (
            !data.ok ||
            !Array.isArray(data.noticias) ||
            data.noticias.length === 0
          ) {
            wrapper.closest(".swiper").style.display = "none";
            return;
          }

          wrapper.innerHTML = data.noticias
            .map((n, i) => {
              const fecha = currentLang === "es" ? n.fecha_es : n.fecha_en;
              const titulo = currentLang === "es" ? n.titulo_es : n.titulo_en;
              const contenido =
                currentLang === "es" ? n.contenido_es : n.contenido_en;
              const resumen =
                Array.isArray(contenido) && contenido.length > 0
                  ? contenido[0]
                  : typeof contenido === "string"
                    ? contenido
                    : "";
              const imgTag = n.imagen
                ? `<img src="${n.imagen}" alt="${titulo}" class="w-full h-48 object-cover rounded-t-xl" />`
                : `<div class="w-full h-48 rounded-t-xl" style="background:${gradients[i % gradients.length]};"></div>`;

              return `<div class="swiper-slide">
                <div class="bg-white rounded-xl shadow-lg transition-all duration-500 group hover:scale-105 hover:shadow-2xl" style="border-top:4px solid #7dc5b5;">
                  ${imgTag}
                  <div class="p-6">
                    <span class="text-xs font-bold uppercase" style="color:#7dc5b5;">${fecha}</span>
                    <h3 class="font-bold text-lg mt-2 mb-3" style="color:#062d76;">${titulo}</h3>
                    <p class="text-gray-500 text-sm" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">${resumen}</p>
                  </div>
                </div>
              </div>`;
            })
            .join("");

          // Inicializar Swiper AHORA que los slides ya están en el DOM
          new Swiper(".swiper-noticias", {
            modules: [Navigation, Pagination, Autoplay],
            slidesPerView: 1.2,
            spaceBetween: 20,
            loop: data.noticias.length > 2,
            autoplay: { delay: 3500, disableOnInteraction: false },
            navigation: {
              nextEl: "#news-next",
              prevEl: "#news-prev",
            },
            pagination: {
              el: ".swiper-pagination-noticias",
              clickable: true,
            },
            breakpoints: {
              640: { slidesPerView: 1.5, spaceBetween: 20 },
              1024: { slidesPerView: 2.2, spaceBetween: 24 },
            },
          });
        })
        .catch((err) => {
          console.error("Error cargando noticias en home:", err);
          wrapper.closest(".swiper").style.display = "none";
        });
    };

    window.__initHomeNews(Swiper, Navigation, Pagination, Autoplay);
  </script>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
        } else {
          entry.target.classList.remove("in-view");
        }
      });
    });
    document
      .querySelectorAll(
        ".animate-on-load, .animate-on-load-delay-1, .animate-on-load-delay-2",
      )
      .forEach((el) => {
        observer.observe(el);
      });

    // --- Tipo de Cambio (Dólar DOF) ---
    const indForm = document.getElementById("indicators-form");
    const indModal = document.getElementById("indicators-modal");
    const indModalCard = document.getElementById("indicators-modal-card");
    const indCloseBtn = document.getElementById("indicators-modal-close-btn");
    const indCloseFooter = document.getElementById("indicators-modal-close-footer");

    if (indForm && indModal && indModalCard) {
      const inputStart = document.getElementById("ind-start-date");
      const inputEnd = document.getElementById("ind-end-date");

      const today = new Date();
      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(today.getDate() - 7);

      const formatDateInput = function (d) {
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const dd = String(d.getDate()).padStart(2, '0');
        return yyyy + "-" + mm + "-" + dd;
      };

      if (inputStart && inputEnd) {
        inputStart.value = formatDateInput(sevenDaysAgo);
        inputEnd.value = formatDateInput(today);
        inputStart.max = formatDateInput(today);
        inputEnd.max = formatDateInput(today);
      }

      const openIndModal = function () {
        indModal.style.display = "flex";
        setTimeout(function () {
          indModal.classList.remove("opacity-0");
          indModal.classList.add("opacity-100");
          indModalCard.classList.remove("scale-95");
          indModalCard.classList.add("scale-100");
        }, 10);
      };

      const closeIndModal = function () {
        indModal.classList.remove("opacity-100");
        indModal.classList.add("opacity-0");
        indModalCard.classList.remove("scale-100");
        indModalCard.classList.add("scale-95");
        setTimeout(function () {
          indModal.style.display = "none";
        }, 300);
      };

      indCloseBtn?.addEventListener("click", closeIndModal);
      indCloseFooter?.addEventListener("click", closeIndModal);
      indModal.addEventListener("click", function (e) {
        if (e.target === indModal) closeIndModal();
      });

      const parseDateStr = function (dStr) {
        const parts = dStr.split('-');
        return new Date(parseInt(parts[2], 10), parseInt(parts[1], 10) - 1, parseInt(parts[0], 10));
      };

      indForm.addEventListener("submit", async function (e) {
        e.preventDefault();

        const startDate = inputStart.value;
        const endDate = inputEnd.value;

        if (new Date(startDate) > new Date(endDate)) {
          alert(indForm.dataset.validationText || "Rango de fechas no válido");
          return;
        }

        openIndModal();

        const loader = document.getElementById("ind-modal-loading");
        const errorDiv = document.getElementById("ind-modal-error");
        const dataWrapper = document.getElementById("ind-modal-data-wrapper");
        const tableBody = document.getElementById("ind-table-body");

        loader?.classList.remove("hidden");
        errorDiv?.classList.add("hidden");
        dataWrapper?.classList.add("hidden");

        try {
          const base = window.location.hostname === "localhost" ? "http://localhost/antal24" : "";
          const response = await fetch(base + "/admin/indicadores.php?fechaInicio=" + startDate + "&fechaFin=" + endDate);

          if (!response.ok) throw new Error("HTTP Error");

          const data = await response.json();

          if (data.messageCode !== 200 || !Array.isArray(data.ListaIndicadores)) {
            throw new Error("Invalid response structure");
          }

          if (data.ListaIndicadores.length === 0) {
            if (errorDiv) {
              errorDiv.textContent = indForm.dataset.noDataText || "No data";
              errorDiv.classList.remove("hidden");
            }
            loader?.classList.add("hidden");
            return;
          }

          const sorted = data.ListaIndicadores.sort(function (a, b) {
            return parseDateStr(b.fecha).getTime() - parseDateStr(a.fecha).getTime();
          });

          if (tableBody) {
            tableBody.innerHTML = sorted.map(function (item) {
              return '<tr class="bg-white border-b border-gray-100 hover:bg-gray-50/50 transition-colors">' +
                '<td class="px-6 py-3.5 font-medium text-secondary-color">' + item.fecha + '</td>' +
                '<td class="px-6 py-3.5 font-bold text-primary-color">$' + parseFloat(item.valor).toFixed(4) + ' <span class="text-xs font-normal text-gray-400">MXN</span></td>' +
                '</tr>';
            }).join('');
          }

          loader?.classList.add("hidden");
          dataWrapper?.classList.remove("hidden");

        } catch (err) {
          console.error("Error al consultar el tipo de cambio:", err);
          if (errorDiv) {
            errorDiv.textContent = indForm.dataset.errorText || "Error";
            errorDiv.classList.remove("hidden");
          }
          loader?.classList.add("hidden");
        }
      });
    }
  </script>
</Layout>
