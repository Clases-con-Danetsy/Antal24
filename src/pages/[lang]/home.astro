---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/Header.astro";
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang || "es";
import { translations } from "../../locales.js";
const t = translations[lang as keyof typeof translations] ?? translations["es"];
---

<Layout lang={lang}>
  <Header lang={lang} />

  <!-- HERO -->
  <section
    <section
    class="relative min-h-[700px] md:min-h-[80vh] flex items-center justify-center bg-secondary-color overflow-hidden"
  >
    >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1600"
        alt="hero"
        class="w-full h-full object-cover opacity-30"
      />
    </div>
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <h1
        class="text-3xl md:text-7xl font-bold text-white mb-6 leading-tight"
        style="font-family: 'Trebuchet MS', sans-serif;"
      >
        Get it easy, <span style="color: #39a08b;">get it safe!</span>
      </h1>
      <p class="text-xl md:text-2xl text-white mb-10 opacity-90">
        {t.hero.subtitle}
      </p>
    </div>
  </section>

  <div class="w-full h-1 bg-primary-color"></div>

  <!-- 3 PILARES -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div
        class="relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=600"
          alt="Comercializadora"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 opacity-40"></div>
        <div
          class="absolute inset-0 bg-secondary-color opacity-0 group-hover:opacity-60 transition-opacity duration-500"
        >
        </div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.comercializadora}</h3>
          <div
            class="w-10 h-0.5 bg-primary-color mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
        </div>
      </div>

      <div
        class="relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="https://images.unsplash.com/photo-1577705998148-6da4f3963bc8?w=600"
          alt="Logística"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 opacity-40"></div>
        <div
          class="absolute inset-0 bg-secondary-color opacity-0 group-hover:opacity-60 transition-opacity duration-500"
        >
        </div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.logistica}</h3>
          <div
            class="w-10 h-0.5 bg-primary-color mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
        </div>
      </div>

      <div
        class="relative text-white rounded-xl overflow-hidden shadow-lg hover:scale-105 transition-transform h-48 group"
      >
        <img
          src="https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=600"
          alt="Despacho Aduanal"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 opacity-40"></div>
        <div
          class="absolute inset-0 bg-secondary-color opacity-0 group-hover:opacity-60 transition-opacity duration-500"
        >
        </div>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl mb-4"></div>
          <h3 class="text-2xl font-bold">{t.pillars.aduanal}</h3>
          <div
            class="w-10 h-0.5 bg-primary-color mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-secondary-color text-center mb-4">
        {t.services.title}
      </h2>
      <div class="w-24 h-1 bg-primary-color mx-auto mb-14"></div>
    </div>
    <div class="max-w-5xl mx-auto px-6 overflow-hidden">
      <div class="carousel-track flex gap-6" id="carousel1">
        {
          [...t.services.items, ...t.services.items].map(
            (service: { title: string; desc: string }, i: number) => (
              <div
                class="flex-shrink-0 relative rounded-xl overflow-hidden shadow-lg group h-72"
                style="width: 320px"
              >
                <img
                  src={`https://images.unsplash.com/photo-${["1494412574643-ff11b0a5c1c3", "1578575437130-527eed3abbec", "1566633806827-5db022039827", "1521737852567-6949f3f9f2b5", "1586528116311-ad8dd3c8310d", "1601584672943-7e23070b7bc1", "1494412574643-ff11b0a5c1c3"][i % 7]}?w=600`}
                  alt={service.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-125"
                />
                <div class="absolute inset-0 opacity-60 group-hover:opacity-40 transition-opacity duration-500" />
                <div class="absolute inset-0 flex flex-col justify-end p-6">
                  <h3 class="text-white font-bold text-xl mb-2">
                    {service.title}
                  </h3>
                  <p class="text-white text-sm opacity-90">{service.desc}</p>
                  <span class="text-primary-color font-bold mt-3 text-sm" />
                </div>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- SERVICIOS LOGÍSTICOS -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-secondary-color text-center mb-4">
        {t.services.logisticsTitle}
      </h2>
      <div class="w-24 h-1 bg-primary-color mx-auto mb-14"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          t.services.logistics.map(
            (service: { title: string; desc: string }, i: number) => (
              <div class="relative rounded-xl overflow-hidden shadow-lg group h-64">
                <img
                  src={`https://images.unsplash.com/photo-${["1577705998148-6da4f3963bc8", "1494412574643-ff11b0a5c1c3", "1578575437130-527eed3abbec", "1566633806827-5db022039827"][i % 4]}?w=600`}
                  alt={service.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-125"
                />
                <div class="absolute inset-0 opacity-0 group-hover:opacity-60 transition-opacity duration-500" />
                <div class="absolute inset-0 flex flex-col justify-end p-6">
                  <h3 class="text-white font-bold text-xl mb-2">
                    {service.title}
                  </h3>
                  <p class="text-white text-sm opacity-90">{service.desc}</p>
                  <span class="text-primary-color font-bold mt-3 text-sm" />
                </div>
              </div>
            ),
          )
        }
      </div>
    </div>
  </section>

  <!-- COBERTURA MAPA-->
  <section class="py-20 bg-secondary-color">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-white text-center mb-4">
        {t.coverage.title}
      </h2>
      <div class="w-24 h-1 bg-primary-color mx-auto mb-10"></div>
      <p
        class="text-white text-center text-lg max-w-2xl mx-auto mb-12 opacity-90"
      >
        {t.coverage.desc}
      </p>

      <div class="bg-white rounded-xl p-8 shadow-2xl">
        <div
          class="relative w-full rounded-lg overflow-hidden pb-[80%] md:pb-[60%]"
        >
          <iframe
            class="absolute inset-0 w-full h-full"
            src="https://www.google.com/maps/d/embed?mid=1OCzcRGtfFUAl_Ie1rz0WqofWERhC4zk"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"></iframe>
          <div
            class="absolute top-0 left-0 w-full bg-white"
            style="height: 60px; z-index: 10;"
          >
          </div>
        </div>

        <!-- Leyenda -->
        <div class="flex flex-wrap justify-center gap-6 mt-6">
          {
            [
              { city: "Quintana Roo", color: "bg-primary-color" },
              { city: "Yucatán", color: "bg-primary-color" },
              { city: "CDMX", color: "bg-primary-color" },
              { city: "Nuevo Laredo", color: "bg-primary-color" },
            ].map((item) => (
              <div class="flex items-center gap-2">
                <div class={`w-4 h-4 rounded-full ${item.color}`} />
                <span class="text-secondary-color font-bold text-sm">
                  {item.city}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- NOTICIAS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-secondary-color text-center mb-4">
        {t.news.title}
      </h2>
      <div class="w-24 h-1 bg-primary-color mx-auto mb-14"></div>
      <div class="overflow-hidden">
        <div class="news-track flex gap-6">
          {
            [1, 2, 3, 1, 2, 3].map((n) => (
              <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl hover:-translate-y-13 transition-all duration-500 group w-[260px] md:w-[380px]">
                <img
                  src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=600"
                  alt="noticia"
                  class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-125"
                />
                <div class="p-6">
                  <span class="text-xs text-primary-color font-bold uppercase">
                    Abril 2026
                  </span>
                  <h3 class="text-secondary-color font-bold text-lg mt-2 mb-3">
                    Título de noticia placeholder {n}
                  </h3>
                  <p class="text-gray-500 text-sm">
                    Descripción breve de la noticia. Este contenido será
                    actualizado desde el sistema de gestión.
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="text-center mt-6">
        <a
          href={`/${lang}/news`}
          class="text-secondary-color font-semibold border-2 border-secondary-color
        px-7 py-2 rounded-full hover:bg-secondary-color hover:text-white transition-colors"
        >
          {t.news.viewAll}
        </a>
      </div>
    </div>
  </section>
</Layout>

<!-- FOOTER -->
<footer class="bg-secondary-color py-16 px-6">
  <div
    class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 items-center"
  >
    <!-- Menu -->
    <div>
      <p class="text-white font-bold text-sm uppercase tracking-widest mb-6">
        Menu
      </p>
      <ul class="flex flex-col gap-3">
        <li>
          <a
            href={`/${lang}/home`}
            class="text-white/70 hover:text-primary-color transition-colors text-sm"
            >{t.header.home}</a
          >
        </li>
        <li>
          <a
            href={`/${lang}/services`}
            class="text-white/70 hover:text-primary-color transition-colors text-sm"
            >{t.header.services}</a
          >
        </li>
        <li>
          <a
            href={`/${lang}/about`}
            class="text-white/70 hover:text-primary-color transition-colors text-sm"
            >{t.header.about}</a
          >
        </li>
        <li>
          <a
            href={`/${lang}/contact`}
            class="text-white/70 hover:text-primary-color transition-colors text-sm"
            >{t.header.contact}</a
          >
        </li>
      </ul>
    </div>

    <!-- Logo centrado -->
    <div class="flex justify-center">
      <img
        src="/src/assets/ANTAL-NEGATIVO.svg"
        alt="Antal 24"
        class="h-70 w-auto"
      />
    </div>

    <!-- Redes sociales -->
    <div class="flex justify-end gap-4">
      <a
        href="#"
        class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white hover:border-primary-color hover:text-primary-color transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          ><path
            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
          ></path></svg
        >
      </a>
      <a
        href="#"
        class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white hover:border-primary-color hover:text-primary-color transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          ><path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
          ></path></svg
        >
      </a>
      <a
        href="#"
        class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white hover:border-primary-color hover:text-primary-color transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          ><path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path></svg
        >
      </a>
    </div>
  </div>

  <!-- Línea divisora -->

  <div class="max-w-7xl mx-auto mt-12 pt-6 border-t border-white/20"></div>
</footer>
