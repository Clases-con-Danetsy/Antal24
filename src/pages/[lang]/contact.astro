---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/Header.astro";
import Footer from "../../components/Footer.astro";

export const prerender = true;
export function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang || "es";
import { translations } from "../../locales.js";
const t = translations[lang as keyof typeof translations] ?? translations["es"];
---

<Layout lang={lang}>
    <Header lang={lang} />

    <!-- HERO -->
    <section
        class="relative min-h-[400px] md:min-h-[500px] flex items-center justify-center bg-secondary-color overflow-hidden"
    >
        <div class="absolute inset-0">
            <img
                src="https://images.unsplash.com/photo-1521737852567-6949f3f9f2b5?w=1600"
                alt="contacto"
                class="w-full h-full object-cover opacity-20"
            />
        </div>
        <div class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">
            <h1
                class="text-3xl md:text-6xl font-bold text-white mb-6 leading-tight"
                style="font-family: 'Trebuchet MS', sans-serif;"
            >
                {lang === "es" ? "Con" : "Con"}<span style="color: #39a08b;"
                    >{lang === "es" ? "tacto" : "tact"}</span
                >
            </h1>
            <p class="text-lg md:text-xl text-white opacity-90">
                {
                    lang === "es"
                        ? "¿Tienes alguna duda? Nuestro equipo de atención a clientes estará disponible para dar seguimiento a tus necesidades."
                        : "Do you have any questions? Our customer service team will be available to follow up on your needs."
                }
            </p>
        </div>
    </section>

    <div class="w-full h-1 bg-primary-color"></div>

    <!-- CONTENIDO -->
    <main
        class="max-w-5xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-[1fr_1.4fr] gap-8 items-start"
    >
        <!-- Tarjeta de información -->
        <div
            class="relative bg-secondary-color rounded-2xl p-8 text-white overflow-hidden"
        >
            <div
                class="absolute -bottom-10 -right-10 w-44 h-44 rounded-full bg-primary-color/10"
            >
            </div>

            <span
                class="inline-block text-[10px] font-medium tracking-widest uppercase bg-primary-color/20 text-primary-color px-3 py-1 rounded-full mb-4"
            >
                {
                    lang === "es"
                        ? "Información de contacto"
                        : "Contact information"
                }
            </span>
            <h2
                class="text-lg font-semibold text-white mb-8"
                style="font-family: 'Trebuchet MS', sans-serif;"
            >
                {
                    lang === "es"
                        ? "Contáctanos directamente"
                        : "Contact us directly"
                }
            </h2>

            <!-- Email -->
            <div class="flex items-start gap-4 mb-6 relative z-10">
                <div
                    class="w-10 h-10 rounded-full bg-primary-color/20 flex items-center justify-center shrink-0"
                >
                    <svg
                        class="w-4 h-4 fill-none stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]"
                        style="stroke:#39a08b"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                </div>
                <div>
                    <p
                        class="text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1"
                    >
                        {lang === "es" ? "Correo electrónico" : "Email"}
                    </p>
                    <a
                        href="mailto:contacto@antal.com"
                        class="block text-sm text-primary-color hover:opacity-75 transition-opacity"
                        >contacto@antal.com</a
                    >
                    <a
                        href="mailto:atencion@antal.com"
                        class="block text-sm text-primary-color hover:opacity-75 transition-opacity"
                        >atencion@antal.com</a
                    >
                </div>
            </div>

            <hr class="border-white/10 my-5" />

            <!-- Teléfono -->
            <div class="flex items-start gap-4 mb-6 relative z-10">
                <div
                    class="w-10 h-10 rounded-full bg-primary-color/20 flex items-center justify-center shrink-0"
                >
                    <svg
                        class="w-4 h-4 fill-none stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]"
                        style="stroke:#39a08b"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.42 2 2 0 0 1 3.58 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.72 16.92z"
                        ></path>
                    </svg>
                </div>
                <div>
                    <p
                        class="text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1"
                    >
                        {lang === "es" ? "Teléfono" : "Phone"}
                    </p>
                    <p class="text-sm text-white">+52 (55) 0000-0000</p>
                </div>
            </div>

            <hr class="border-white/10 my-5" />

            <!-- Dirección -->
            <div class="flex items-start gap-4 relative z-10">
                <div
                    class="w-10 h-10 rounded-full bg-primary-color/20 flex items-center justify-center shrink-0"
                >
                    <svg
                        class="w-4 h-4 fill-none stroke-[1.8] [stroke-linecap:round] [stroke-linejoin:round]"
                        style="stroke:#39a08b"
                        viewBox="0 0 24 24"
                    >
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                        ></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </div>
                <div>
                    <p
                        class="text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1"
                    >
                        {lang === "es" ? "Dirección" : "Address"}
                    </p>
                    <p class="text-sm text-white">Ciudad de México, México</p>
                </div>
            </div>
        </div>

        <!-- Formulario -->
        <div
            class="bg-white rounded-2xl p-8 border border-[#adacb1]/40 shadow-[0_4px_32px_rgba(6,45,118,0.06)]"
        >
            <span
                class="inline-block text-[10px] font-medium tracking-widest uppercase bg-primary-color/10 text-primary-color px-3 py-1 rounded-full mb-4"
            >
                {lang === "es" ? "Déjanos un mensaje" : "Leave us a message"}
            </span>
            <h2
                class="text-lg font-semibold text-secondary-color mb-7"
                style="font-family: 'Trebuchet MS', sans-serif;"
            >
                {
                    lang === "es"
                        ? "Te contactamos nosotros"
                        : "We'll contact you"
                }
            </h2>

            <form method="POST" class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label
                            for="nombre"
                            class="block text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1.5"
                        >
                            {lang === "es" ? "Nombre" : "Name"}
                        </label>
                        <input
                            type="text"
                            id="nombre"
                            name="nombre"
                            placeholder={lang === "es"
                                ? "Tu nombre completo"
                                : "Your full name"}
                            required
                            class="w-full border border-[#adacb1] rounded-lg px-4 py-3 text-sm text-gray-800 bg-gray-50 placeholder-[#adacb1] focus:outline-none focus:border-primary-color focus:bg-white transition"
                        />
                    </div>
                    <div>
                        <label
                            for="correo"
                            class="block text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1.5"
                        >
                            {lang === "es" ? "Correo electrónico" : "Email"}
                        </label>
                        <input
                            type="email"
                            id="correo"
                            name="correo"
                            placeholder="correo@ejemplo.com"
                            required
                            class="w-full border border-[#adacb1] rounded-lg px-4 py-3 text-sm text-gray-800 bg-gray-50 placeholder-[#adacb1] focus:outline-none focus:border-primary-color focus:bg-white transition"
                        />
                    </div>
                </div>

                <div>
                    <label
                        for="telefono"
                        class="block text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1.5"
                    >
                        {lang === "es" ? "Teléfono" : "Phone"}
                    </label>
                    <input
                        type="tel"
                        id="telefono"
                        name="telefono"
                        placeholder="+52 (55) 0000-0000"
                        class="w-full border border-[#adacb1] rounded-lg px-4 py-3 text-sm text-gray-800 bg-gray-50 placeholder-[#adacb1] focus:outline-none focus:border-primary-color focus:bg-white transition"
                    />
                </div>

                <div>
                    <label
                        for="mensaje"
                        class="block text-[10px] font-medium tracking-widest uppercase text-[#adacb1] mb-1.5"
                    >
                        {lang === "es" ? "Mensaje" : "Message"}
                    </label>
                    <textarea
                        id="mensaje"
                        name="mensaje"
                        rows="5"
                        placeholder={lang === "es"
                            ? "Escribe tu mensaje aquí..."
                            : "Write your message here..."}
                        required
                        class="w-full border border-[#adacb1] rounded-lg px-4 py-3 text-sm text-gray-800 bg-gray-50 placeholder-[#adacb1] focus:outline-none focus:border-primary-color focus:bg-white transition resize-none"
                    ></textarea>
                </div>

                <button
                    type="submit"
                    class="w-full bg-secondary-color hover:bg-primary-color text-white text-xs font-semibold tracking-widest uppercase py-4 rounded-lg transition-colors duration-300 cursor-pointer"
                >
                    {lang === "es" ? "Enviar mensaje" : "Send message"}
                </button>
            </form>
        </div>
    </main>

    <Footer lang={lang} />
</Layout>
