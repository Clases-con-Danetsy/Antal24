---
import { translations } from "../../locales.js";
const lang = Astro.props?.lang ?? "es";
const t = translations[lang as keyof typeof translations] ?? translations["es"];
const otherLang = lang === "es" ? "en" : "es";
const otherLangLabel = lang === "es" ? "EN" : "ES";
const currentPath = Astro.url.pathname;
const otherLangPath = currentPath.replace(`/${lang}/`, `/${otherLang}/`);

const serviceLinks =
  lang === "es"
    ? [
        {
          label: "Importaciones y Exportaciones",
          anchor: "importaciones-y-exportaciones",
        },
        { label: "Asesoría Legal Aduanal", anchor: "asesoria-legal-aduanal" },
        { label: "Cuaderno ATA", anchor: "cuaderno-ata" },
        {
          label: "Trámites ante BANJERCITO",
          anchor: "tramites-ante-banjercito",
        },
        {
          label: "Certificaciones NOMs de Seguridad",
          anchor: "certificaciones-noms-de-seguridad",
        },
        {
          label: "Cumplimiento de NOMs de Etiquetado",
          anchor: "cumplimiento-de-noms-de-etiquetado",
        },
        { label: "Padrón Sectorial", anchor: "padron-sectorial" },
        {
          label: "Almacén / Depósito Fiscal",
          anchor: "almacen-deposito-fiscal",
        },
      ]
    : [
        { label: "Imports & Exports", anchor: "imports-exports" },
        { label: "Legal Customs Advisory", anchor: "legal-customs-advisory" },
        { label: "ATA Carnet", anchor: "ata-carnet" },
        { label: "BANJERCITO Procedures", anchor: "banjercito-procedures" },
        {
          label: "Safety NOM Certifications",
          anchor: "safety-nom-certifications",
        },
        { label: "Labeling NOM Compliance", anchor: "labeling-nom-compliance" },
        { label: "Sectoral Registry", anchor: "sectoral-registry" },
        {
          label: "Warehouse / Fiscal Deposit",
          anchor: "warehouse-fiscal-deposit",
        },
      ];

const logisticsLinks =
  lang === "es"
    ? [
        { label: "Fletes Terrestres", anchor: "fletes-terrestres" },
        { label: "Logística Internacional", anchor: "logistica-internacional" },
        { label: "Gestoría Marítima", anchor: "gestoria-maritima" },
        { label: "Gestoría Aérea", anchor: "gestoria-aerea" },
      ]
    : [
        { label: "Land Freight", anchor: "land-freight" },
        { label: "International Logistics", anchor: "international-logistics" },
        { label: "Maritime Agency", anchor: "maritime-agency" },
        { label: "Air Agency", anchor: "air-agency" },
      ];
---

<header
  id="main-header"
  class="fixed top-0 left-0 w-full z-50 bg-transparent shadow-none transition-transform duration-300"
>
  <div class="w-full px-6 flex items-center justify-between h-20">
    <!-- Logo que sobresale -->
    <a
      href={`/${lang}/home`}
      class="relative z-10 bg-white rounded-b-2xl px-4 pb-2 md:pb-16 pt-2 md:pt-6 shadow-md mt-4 md:mt-36 ml-0 md:ml-40"
    >
      <img
        src="/logos/Antal-Colores.svg"
        alt="Antal 24"
        class="h-20 md:h-40 w-auto"
      />
    </a>

    <!-- Nav centrado -->
    <nav class="hidden md:flex items-center gap-8 ml-auto">
      <a
        href={`/${lang}/home`}
        class="text-white font-bold hover:text-primary-color transition-colors"
      >
        {t.header.home}
      </a>

      <!-- Servicios con dropdown -->
      <div class="relative group">
        <a
          href={`/${lang}/services`}
          class="text-white font-bold hover:text-primary-color transition-colors flex items-center gap-1"
        >
          {t.header.services}
          <svg
            class="w-3 h-3 mt-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <div
          class="absolute top-full left-0 mt-2 w-72 bg-white rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2"
        >
          <!-- Servicios -->
          <p
            class="px-4 pt-2 pb-1 text-[10px] font-bold uppercase tracking-widest text-[#adacb1]"
          >
            {lang === "es" ? "Servicios" : "Services"}
          </p>
          {
            serviceLinks.map((item) => (
              <a
                href={`/${lang}/services#${item.anchor}`}
                class="block px-4 py-2 text-sm text-secondary-color hover:bg-gray-50 hover:text-primary-color transition-colors font-medium"
              >
                {item.label}
              </a>
            ))
          }

          <!-- Separador -->
          <div class="my-2 mx-4 border-t border-gray-100"></div>

          <!-- Logística -->
          <p
            class="px-4 pt-1 pb-1 text-[10px] font-bold uppercase tracking-widest text-[#adacb1]"
          >
            {lang === "es" ? "Logística" : "Logistics"}
          </p>
          {
            logisticsLinks.map((item) => (
              <a
                href={`/${lang}/services#${item.anchor}`}
                class="block px-4 py-2 text-sm text-secondary-color hover:bg-gray-50 hover:text-primary-color transition-colors font-medium"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>

      <a
        href={`/${lang}/about`}
        class="text-white font-bold hover:text-primary-color transition-colors"
      >
        {t.header.about}
      </a>
      <a
        href={`/${lang}/news`}
        class="text-white font-bold hover:text-primary-color transition-colors"
      >
        {t.header.news}
      </a>
    </nav>

    <!-- Lang switcher + CTA desktop -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href={otherLangPath}
        class="text-white font-bold hover:text-primary-color transition-colors ml-4"
      >
        <span class={lang === "es" ? "text-primary-color" : "text-white"}
          >ES</span
        >
        <span class="text-white mx-1">|</span>
        <span class={lang === "en" ? "text-primary-color" : "text-white"}
          >EN</span
        >
      </a>
      <a
        href={`/${lang}/contact`}
        class="bg-primary-color text-white px-5 py-2 rounded font-bold hover:opacity-90 transition-opacity"
      >
        {t.header.contact}
      </a>
    </div>

    <!-- Hamburger mobile -->
    <button id="menu-btn" class="md:hidden text-white focus:outline-none">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Menu mobile -->
  <div
    id="mobile-menu"
    class="hidden bg-secondary-color flex-col fixed inset-0 top-0 z-40 items-center justify-center overflow-y-auto py-20"
  >
    <!-- Botón cerrar -->
    <button
      id="close-btn"
      class="absolute top-6 right-6 text-white focus:outline-none"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Logo -->
    <div class="mb-8">
      <img src="/logos/Antal-Blanco.svg" alt="Antal 24" class="h-40 w-auto" />
    </div>

    <!-- Links -->
    <a
      href={`/${lang}/home`}
      class="text-white font-bold hover:text-primary-color transition-colors text-2xl mb-5"
    >
      {t.header.home}
    </a>

    <!-- Servicios mobile -->
    <div class="flex flex-col items-center w-full">
      <button
        id="mobile-services-btn"
        class="text-white font-bold hover:text-primary-color transition-colors text-2xl mb-3 flex items-center gap-2"
      >
        {t.header.services}
        <svg
          id="mobile-services-arrow"
          class="w-5 h-5 transition-transform duration-200"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      <div
        id="mobile-services-list"
        class="hidden flex-col items-center gap-3 mb-5 w-full px-8"
      >
        <!-- Servicios -->
        <p
          class="text-[#adacb1] text-xs font-bold uppercase tracking-widest mt-1"
        >
          {lang === "es" ? "Servicios" : "Services"}
        </p>
        {
          serviceLinks.map((item) => (
            <a
              href={`/${lang}/services#${item.anchor}`}
              class="text-white font-semibold hover:text-primary-color transition-colors text-lg text-center"
            >
              {item.label}
            </a>
          ))
        }

        <!-- Logística -->
        <p
          class="text-[#adacb1] text-xs font-bold uppercase tracking-widest mt-3"
        >
          {lang === "es" ? "Logística" : "Logistics"}
        </p>
        {
          logisticsLinks.map((item) => (
            <a
              href={`/${lang}/services#${item.anchor}`}
              class="text-white font-semibold hover:text-primary-color transition-colors text-lg text-center"
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>

    <a
      href={`/${lang}/about`}
      class="text-white font-bold hover:text-primary-color transition-colors text-2xl mb-5"
    >
      {t.header.about}
    </a>
    <a
      href={`/${lang}/news`}
      class="text-white font-bold hover:text-primary-color transition-colors text-2xl mb-5"
    >
      {t.header.news}
    </a>
    <a
      href={`/${lang}/contact`}
      class="text-white font-bold hover:text-primary-color transition-colors text-2xl mb-5"
    >
      {t.header.contact}
    </a>

    <!-- Lang switcher -->
    <div class="mt-4">
      <a href={otherLangPath} class="text-white font-bold text-xl">
        <span class={lang === "es" ? "text-primary-color" : "text-white"}
          >ES</span
        >
        <span class="text-white mx-1">|</span>
        <span class={lang === "en" ? "text-primary-color" : "text-white"}
          >EN</span
        >
      </a>
    </div>

    <!-- Línea decorativa -->
    <div class="absolute bottom-10 w-16 h-1 bg-primary-color rounded-full">
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const closeBtn = document.getElementById("close-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
    const logo = document.querySelector("#main-header a");
    logo?.classList.toggle("invisible");
  });

  closeBtn?.addEventListener("click", () => {
    menu?.classList.add("hidden");
    menu?.classList.remove("flex");
    const logo = document.querySelector("#main-header a");
    logo?.classList.remove("invisible");
  });

  const mobileServicesBtn = document.getElementById("mobile-services-btn");
  const mobileServicesList = document.getElementById("mobile-services-list");
  const mobileServicesArrow = document.getElementById("mobile-services-arrow");

  mobileServicesBtn?.addEventListener("click", () => {
    mobileServicesList?.classList.toggle("hidden");
    mobileServicesList?.classList.toggle("flex");
    mobileServicesArrow?.classList.toggle("rotate-180");
  });

  const header = document.getElementById("main-header");
  window.addEventListener("scroll", () => {
    if (window.innerWidth >= 768) {
      if (window.scrollY > 100) {
        header?.classList.add("-translate-y-[250%]");
      } else {
        header?.classList.remove("-translate-y-[250%]");
      }
    }
  });

  // Cerrar menu al hacer clic en cualquier enlace
  document.querySelectorAll("#mobile-menu a").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      const logo = document.querySelector("#main-header a");
      logo?.classList.remove("invisible");
    });
  });
</script>
