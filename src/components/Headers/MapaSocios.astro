---
const { lang = "es" } = Astro.props;

const texts = {
  es: { title: "Socios Comerciales" },
  en: { title: "Commercial Partners" },
};

const t = texts[lang as keyof typeof texts] ?? texts["es"];

const partners = {
  es: [
    {
      id: "usa",
      name: "Estados Unidos",
      flag: "🇺🇸",
      city: ["New York", "Los Angeles", "Miami", "Houston"],
      services: ["Fletes internacionales", "Previos en origen", "Almacenaje"],
      coords: [-98, 38],
    },
    {
      id: "de",
      name: "Alemania",
      flag: "🇩🇪",
      city: ["Berlín", "Hamburgo", "Frankfurt"],
      services: ["Fletes internacionales", "Almacenaje"],
      coords: [13, 52],
    },
    {
      id: "es",
      name: "España",
      flag: "🇪🇸",
      city: ["Madrid", "Barcelona", "Valencia"],
      services: ["Fletes internacionales", "Almacén", "Previo en origen"],
      coords: [-3, 40],
    },
    {
      id: "cn",
      name: "China",
      flag: "🇨🇳",
      city: ["Shanghai", "Beijing", "Guangzhou"],
      services: [
        "Fletes internacionales",
        "Previos en origen",
        "Inspección de proveedores",
      ],
      coords: [104, 35],
    },
    {
      id: "eu",
      name: "Europa",
      flag: "🇪🇺",
      city: ["Unión Europea"],
      services: ["Fletes internacionales"],
      coords: [20, 60],
    },
  ],
  en: [
    {
      id: "usa",
      name: "United States",
      flag: "🇺🇸",
      city: ["New York", "Los Angeles", "Miami", "Houston"],
      services: ["International freight", "Origin inspections", "Warehousing"],
      coords: [-98, 38],
    },
    {
      id: "de",
      name: "Germany",
      flag: "🇩🇪",
      city: ["Berlin", "Hamburg", "Frankfurt"],
      services: ["International freight", "Warehousing"],
      coords: [13, 52],
    },
    {
      id: "es",
      name: "Spain",
      flag: "🇪🇸",
      city: ["Madrid", "Barcelona", "Valencia"],
      services: ["International freight", "Warehousing", "Origin inspections"],
      coords: [-3, 40],
    },
    {
      id: "cn",
      name: "China",
      flag: "🇨🇳",
      city: ["Shanghai", "Beijing", "Guangzhou"],
      services: [
        "International freight",
        "Origin inspections",
        "Supplier inspection",
      ],
      coords: [104, 35],
    },
    {
      id: "eu",
      name: "Europe",
      flag: "🇪🇺",
      city: ["European Union"],
      services: ["International freight"],
      coords: [20, 60],
    },
  ],
};

const currentPartners =
  partners[lang as keyof typeof partners] ?? partners["es"];
const partnerData = JSON.stringify(currentPartners);
---

<section class="py-20 bg-secondary-color">
  <div class="max-w-7xl mx-auto px-6">
    <h2
      data-aos="fade-up"
      class="text-4xl font-bold text-center mb-4"
      style="color: #ffc000;"
    >
      {t.title}
    </h2>
    <div
      data-aos="fade-up"
      data-aos-delay="100"
      class="w-24 h-1 mx-auto mb-10"
      style="background-color: #ffc000;"
    >
    </div>

    <div data-aos="zoom-in" data-aos-delay="200">
      <div id="antal-map" class="w-full" style="overflow: hidden;"></div>
    </div>

    <div class="flex flex-wrap justify-center gap-8 mt-1">
      {
        currentPartners.map((p) => (
          <div class="flex items-center gap-2">
            <svg
              width="12"
              height="18"
              viewBox="0 0 12 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6 0C2.69 0 0 2.69 0 6C0 10.5 6 18 6 18C6 18 12 10.5 12 6C12 2.69 9.31 0 6 0Z"
                fill="#ffc000"
              />
              <circle cx="6" cy="6" r="2.5" fill="white" />
            </svg>
            <span class="font-bold text-sm" style="color: #ffc000;">
              {p.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Modal estilo 4 -->
<div
  id="mapa-modal"
  style="display:none; position:fixed; inset:0; z-index:50; align-items:center; justify-content:center; background:rgba(6,45,118,0.88);"
>
  <div
    style="position:relative; border-radius:16px; max-width:340px; width:90%; background:#062d76; border:1.5px solid #ffc000; overflow:hidden;"
  >
    <button
      id="modal-close"
      style="position:absolute; top:1rem; right:1rem; background:none; border:none; color:#ffc000; cursor:pointer; font-size:1.2rem; z-index:2;"
      >✕</button
    >
    <div
      style="background:linear-gradient(135deg, #0a3d6e, #062d76); padding:1.25rem; display:flex; justify-content:space-between; align-items:flex-start;"
    >
      <div>
        <div id="modal-flag" style="font-size:2rem; margin-bottom:4px;"></div>
        <div
          id="modal-title"
          style="color:white; font-size:1.1rem; font-weight:700;"
        >
        </div>
        <div id="modal-city" style="color:#7dc5b5; font-size:0.75rem;"></div>
      </div>
      <span
        style="background:#ffc000; color:#062d76; font-size:0.65rem; font-weight:700; padding:3px 8px; border-radius:20px; white-space:nowrap; margin-top:4px;"
        >Socio</span
      >
    </div>
    <div
      style="padding:1rem 1.25rem; border-top:1px solid rgba(255,192,0,0.3);"
    >
      <div
        id="modal-services"
        style="display:flex; flex-direction:column; gap:8px;"
      >
      </div>
    </div>
  </div>
</div>

<style is:global>
  @keyframes pin-bounce {
    0%,
    100% {
      transform: translateY(0px);
    }
    40% {
      transform: translateY(-10px);
    }
    70% {
      transform: translateY(-4px);
    }
  }
  .antal-pin {
    animation: pin-bounce 1.8s ease-in-out infinite;
  }
</style>

<script define:vars={{ partnerData }}>
  const partners = JSON.parse(partnerData);
  const pinPath =
    "M0,-18 C6,-18 12,-12 12,-6 C12,4 0,18 0,18 C0,18 -12,4 -12,-6 C-12,-12 -6,-18 0,-18 Z";

  async function initMap() {
    const [d3Module, topoModule] = await Promise.all([
      import("https://cdn.jsdelivr.net/npm/d3@7/+esm"),
      import("https://cdn.jsdelivr.net/npm/topojson-client@3/+esm"),
    ]);

    const d3 = d3Module;
    const W = 1400,
      H = 700;
    const container = document.getElementById("antal-map");
    if (!container) return;

    const svg = d3
      .select(container)
      .append("svg")
      .attr("viewBox", `0 0 ${W} ${H}`)
      .attr("preserveAspectRatio", "xMidYMid meet")
      .style("width", "100%")
      .style("height", "auto")
      .style("display", "block");

    const proj = d3
      .geoNaturalEarth1()
      .scale(255)
      .translate([W / 2, H / 2]);
    const pathGen = d3.geoPath().projection(proj);

    const world = await d3.json(
      "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
    );
    const countries = topoModule.feature(world, world.objects.countries);

    svg
      .selectAll("path.country")
      .data(countries.features.filter((d) => d.id !== "010"))
      .enter()
      .append("path")
      .attr("d", pathGen)
      .style("fill", "#1a5c4a")
      .style("stroke", "#7dc5b5")
      .style("stroke-width", "0.5")
      .on("mouseover", function () {
        d3.select(this).style("fill", "#226b57");
      })
      .on("mouseout", function () {
        d3.select(this).style("fill", "#1a5c4a");
      });

    const usaPos = proj(partners[0].coords);

    partners.forEach((p, i) => {
      const pos = proj(p.coords);

      if (i > 0) {
        svg
          .append("path")
          .style("stroke", "#ffc000")
          .style("stroke-width", "0.5")
          .style("stroke-dasharray", "5 4")
          .style("opacity", "0.4")
          .style("fill", "none")
          .attr(
            "d",
            `M${usaPos[0]},${usaPos[1] - 10} Q${(usaPos[0] + pos[0]) / 2},${Math.min(usaPos[1], pos[1]) - 55} ${pos[0]},${pos[1] - 10}`,
          );
      }

      const g = svg
        .append("g")
        .attr("class", "antal-pin")
        .attr("id", `pin-${p.id}`)
        .style("cursor", "pointer")
        .style("animation-delay", `${i * 0.5}s`)
        .on("click", () => openModal(p));

      const pulse = g
        .append("circle")
        .attr("cx", pos[0])
        .attr("cy", pos[1] - 6)
        .attr("r", 8)
        .style("fill", "#ffc000")
        .style("opacity", "0.5");

      let start = null;
      const delay = i * 500;
      function animatePulse(ts) {
        if (!start) start = ts + delay;
        const elapsed = (ts - start) % 2000;
        if (elapsed >= 0) {
          const progress = elapsed / 2000;
          pulse
            .attr("r", 8 + progress * 16)
            .style("opacity", 0.5 * (1 - progress));
        }
        requestAnimationFrame(animatePulse);
      }
      requestAnimationFrame(animatePulse);

      g.append("path")
        .attr("d", pinPath)
        .attr("transform", `translate(${pos[0]}, ${pos[1]})`)
        .style("fill", "#ffc000")
        .style("stroke", "white")
        .style("stroke-width", "1.2")
        .style("filter", "drop-shadow(0px 2px 4px rgba(0,0,0,0.5))");

      g.append("circle")
        .attr("cx", pos[0])
        .attr("cy", pos[1] - 6)
        .attr("r", 3)
        .style("fill", "white")
        .style("opacity", "0.9");

      g.append("text")
        .attr("x", pos[0])
        .attr("y", pos[1] + 28)
        .style("fill", "#ffc000")
        .style("font-size", "9px")
        .style("font-weight", "bold")
        .style("text-anchor", "middle")
        .style("pointer-events", "none")
        .style("font-family", "Trebuchet MS, sans-serif")
        .text(p.name);
    });
  }

  function openModal(p) {
    document.getElementById("modal-flag").textContent = p.flag;
    document.getElementById("modal-title").textContent = p.name;
    document.getElementById("modal-city").textContent = Array.isArray(p.city)
      ? p.city.join(" · ")
      : p.city;

    const servicesEl = document.getElementById("modal-services");
    servicesEl.innerHTML = "";
    (p.services || []).forEach((s, i) => {
      const row = document.createElement("div");
      row.style.cssText = "display:flex; align-items:center; gap:10px;";

      const num = document.createElement("span");
      num.textContent = i + 1;
      num.style.cssText =
        "font-size:0.65rem; font-weight:700; color:#062d76; background:#ffc000; width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0;";

      const text = document.createElement("span");
      text.textContent = s;
      text.style.cssText = "font-size:0.82rem; color:rgba(255,255,255,0.85);";

      row.appendChild(num);
      row.appendChild(text);
      servicesEl.appendChild(row);
    });

    document.getElementById("mapa-modal").style.display = "flex";
  }

  document.getElementById("modal-close")?.addEventListener("click", () => {
    document.getElementById("mapa-modal").style.display = "none";
  });

  document
    .getElementById("mapa-modal")
    ?.addEventListener("click", function (e) {
      if (e.target === this) this.style.display = "none";
    });

  initMap();
</script>
